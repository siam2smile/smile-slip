I0414 14:05:49.138391    1683 conn_opt.go:53] jsonrpc2: --> notif: textDocument/didChange: {"textDocument":{"uri":"file:///home/smileslip_official/smileslip-dashboard/pages/dashboard.js","version":2},"contentChanges":[{"range":{"start":{"line":0,"character":0},"end":{"line":16,"character":0}},"rangeLength":860,"text":"import React, { useState, useEffect } from 'react';\nimport { useRouter } from 'next/router';\nimport { createClient } from '@supabase/supabase-js';\nimport { LayoutDashboard, Receipt, Settings, LogOut, Edit3, CheckCircle2, Search } from 'lucide-react';\n\nconst supabase = createClient(process.env.NEXT_PUBLIC_SUPABASE_URL, process.env.NEXT_PUBLIC_SUPABASE_KEY);\n\nexport default function Dashboard() {\n  const router = useRouter();\n  const { userId } = router.query;\n  const [transactions, setTransactions] = useState([]);\n  const [shopInfo, setShopInfo] = useState(null);\n\n  useEffect(() =\u003e {\n    if (userId) {\n      const fetchData = async () =\u003e {\n        const { data: shop } = await supabase.from('shop_profiles').select('*').eq('owner_line_id', userId).single();\n        setShopInfo(shop);\n        if (shop) {\n          const { data: txs } = await supabase.from('ledger_transactions').select('*').eq('shop_id', shop.id).order('created_at', { ascending: false });\n          setTransactions(txs || []);\n        }\n      };\n      fetchData();\n    }\n  }, [userId]);\n\n  return (\n    \u003cdiv className=\"min-h-screen bg-slate-50 flex\"\u003e\n      \u003cdiv className=\"w-64 bg-indigo-900 text-white p-6 flex flex-col shadow-2xl\"\u003e\n        \u003cdiv className=\"flex items-center gap-3 mb-10 px-2\"\u003e\u003cdiv className=\"bg-white p-2 rounded-xl text-indigo-900 text-xl\"\u003e😊\u003c/div\u003e\u003cspan className=\"font-bold text-xl uppercase tracking-tighter\"\u003eSmile Slip\u003c/span\u003e\u003c/div\u003e\n        \u003cnav className=\"space-y-2 flex-1\"\u003e\u003cbutton className=\"w-full flex items-center gap-3 bg-indigo-800 p-3 rounded-xl\"\u003e\u003cLayoutDashboard size={20}/\u003e หน้าหลัก\u003c/button\u003e\u003c/nav\u003e\n        \u003cbutton onClick={() =\u003e router.push('/login')} className=\"flex items-center gap-3 p-3 text-indigo-300 hover:text-white transition\"\u003e\u003cLogOut size={20}/\u003e ออกจากระบบ\u003c/button\u003e\n      \u003c/div\u003e\n      \u003cdiv className=\"flex-1 p-8\"\u003e\n        \u003cheader className=\"mb-8\"\u003e\n          \u003ch1 className=\"text-3xl font-bold text-slate-900\"\u003eสวัสดีค่ะคุณ {shopInfo?.shop_name || 'Vespa'}\u003c/h1\u003e\n          \u003cp className=\"text-slate-500\"\u003eนี่คือรายงานสลิปของบริษัทคุณค่ะ\u003c/p\u003e\n        \u003c/header\u003e\n        \u003cdiv className=\"bg-white rounded-3xl shadow-sm border border-slate-100 overflow-hidden\"\u003e\n          \u003ctable className=\"w-full text-left\"\u003e\n            \u003cthead className=\"bg-slate-50 text-slate-400 text-xs uppercase font-bold\"\u003e\n              \u003ctr\u003e\u003cth className=\"p-5\"\u003eวัน-เวลา\u003c/th\u003e\u003cth className=\"p-5\"\u003eผู้โอน\u003c/th\u003e\u003cth className=\"p-5 text-right\"\u003eจำนวนเงิน\u003c/th\u003e\u003cth className=\"p-5 text-center\"\u003eจัดการ\u003c/th\u003e\u003c/tr\u003e\n            \u003c/thead\u003e\n            \u003ctbody\u003e\n              {transactions.map(tx =\u003e (\n                \u003ctr key={tx.id} className=\"border-b border-slate-50\"\u003e\n                  \u003ctd className=\"p-5 text-sm\"\u003e{new Date(tx.created_at).toLocaleString('th-TH')}\u003c/td\u003e\n                  \u003ctd className=\"p-5 font-bold\"\u003e{tx.sender_name || 'ไม่ระบุชื่อ'}\u003c/td\u003e\n                  \u003ctd className=\"p-5 text-right font-bold text-indigo-600\"\u003e฿{tx.amount}\u003c/td\u003e\n                  \u003ctd className=\"p-5 text-center\"\u003e\u003cbutton className=\"p-2 hover:bg-indigo-50 text-indigo-600 rounded-lg\"\u003e\u003cEdit3 size={18}/\u003e\u003c/button\u003e\u003c/td\u003e\n                \u003c/tr\u003e\n              ))}\n            \u003c/tbody\u003e\n          \u003c/table\u003e\n        \u003c/div\u003e\n"}]}
