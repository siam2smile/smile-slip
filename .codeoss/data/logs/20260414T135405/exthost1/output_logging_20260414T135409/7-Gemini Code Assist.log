I0414 13:54:33.022714    1683 conn_opt.go:53] jsonrpc2: --> notif: textDocument/didOpen: {"textDocument":{"uri":"file:///home/smileslip_official/smileslip-dashboard/pages/register.js","languageId":"javascript","version":1,"text":"import React, { useState, useEffect } from 'react';\nimport { useRouter } from 'next/router';\nimport axios from 'axios';\n\nexport default function Register() {\n  const router = useRouter();\n  const [isReady, setIsReady] = useState(false);\n  const [userType, setUserType] = useState('individual');\n  const [formData, setFormData] = useState({ shopName: '', taxId: '', phone: '', address: '' });\n  const [loading, setLoading] = useState(false);\n\n  useEffect(() =\u003e {\n    if (router.isReady) setIsReady(true);\n  }, [router.isReady]);\n\n  const handleSubmit = async (e) =\u003e {\n    e.preventDefault();\n    setLoading(true);\n    try {\n      const res = await axios.post('/api/register', {\n        ...formData,\n        userType,\n        lineUserId: router.query.userId,\n        ownerName: router.query.name || 'คุณลูกค้า'\n      });\n      alert(\"บันทึกสำเร็จ!\");\n      router.push('/');\n    } catch (err) {\n      // ตรงนี้แหละครับที่จะแฉ Error ออกมา\n      const errorMsg = err.response?.data?.error || err.message;\n      console.error(\"Debug Error:\", err.response?.data);\n      alert(\"❌ บันทึกไม่สำเร็จเพราะ: \" + errorMsg);\n    }\n    setLoading(false);\n  };\n\n  if (!isReady) return \u003cdiv className=\"p-10 text-center\"\u003eกำลังเตรียมระบบ... 😊\u003c/div\u003e;\n\n  return (\n    \u003cdiv className=\"min-h-screen bg-slate-50 py-10 px-6 font-sans\"\u003e\n      \u003cdiv className=\"max-w-md mx-auto bg-white rounded-3xl shadow-xl p-8\"\u003e\n        \u003ch2 className=\"text-2xl font-bold mb-6 text-center text-indigo-600\"\u003eลงทะเบียนร้านค้า\u003c/h2\u003e\n        \u003cform onSubmit={handleSubmit} className=\"space-y-4\"\u003e\n          \u003cdiv className=\"flex gap-2 p-1 bg-slate-100 rounded-xl\"\u003e\n             \u003cbutton type=\"button\" onClick={() =\u003e setUserType('individual')} className={`flex-1 py-2 rounded-lg ${userType === 'individual' ? 'bg-white shadow text-indigo-600' : ''}`}\u003eบุคคล\u003c/button\u003e\n             \u003cbutton type=\"button\" onClick={() =\u003e setUserType('corporate')} className={`flex-1 py-2 rounded-lg ${userType === 'corporate' ? 'bg-white shadow text-indigo-600' : ''}`}\u003eนิติบุคคล\u003c/button\u003e\n          \u003c/div\u003e\n          \u003cinput required placeholder=\"ชื่อร้าน/บริษัท\" className=\"w-full p-3 border rounded-xl\" onChange={(e) =\u003e setFormData({...formData, shopName: e.target.value})} /\u003e\n          {userType === 'corporate' \u0026\u0026 \u003cinput required placeholder=\"เลขผู้เสียภาษี\" className=\"w-full p-3 border rounded-xl\" onChange={(e) =\u003e setFormData({...formData, taxId: e.target.value})} /\u003e}\n          \u003cinput required placeholder=\"เบอร์โทรศัพท์\" className=\"w-full p-3 border rounded-xl\" onChange={(e) =\u003e setFormData({...formData, phone: e.target.value})} /\u003e\n          \u003ctextarea required placeholder=\"ที่อยู่\" className=\"w-full p-3 border rounded-xl\" rows=\"3\" onChange={(e) =\u003e setFormData({...formData, address: e.target.value})} /\u003e\n          \u003cbutton disabled={loading} className=\"w-full py-4 bg-indigo-600 text-white rounded-xl font-bold\"\u003e\n            {loading ? \"กำลังบันทึก...\" : \"บันทึกข้อมูล\"}\n          \u003c/button\u003e\n        \u003c/form\u003e\n      \u003c/div\u003e\n    \u003c/div\u003e\n  );\n}\n"}}
