I0414 10:01:33.939550    2720 conn_opt.go:53] jsonrpc2: --> notif: textDocument/didOpen: {"textDocument":{"uri":"file:///home/smileslip_official/smileslip-dashboard/pages/register.js","languageId":"javascript","version":1,"text":"import React, { useState } from 'react';\nimport { Building2, User, MapPin, Phone, CreditCard, Heart } from 'lucide-react';\n\nexport default function Register() {\n  const [userType, setUserType] = useState('individual');\n  const [loading, setLoading] = useState(false);\n\n  const handleSubmit = async (e) =\u003e {\n    e.preventDefault();\n    setLoading(true);\n    // ตรงนี้เราจะเชื่อมท่อส่งข้อมูลไปที่หลังบ้านค่ะ\n    alert(\"น้อง Smile Slip กำลังเตรียมข้อมูลให้คุณนะคะ! (ระบบกำลังบันทึก...)\");\n    setLoading(false);\n  };\n\n  return (\n    \u003cdiv className=\"min-h-screen bg-slate-50 py-12 px-6\"\u003e\n      \u003cdiv className=\"max-w-2xl mx-auto bg-white rounded-3xl shadow-xl overflow-hidden border border-indigo-50\"\u003e\n        \u003cdiv className=\"bg-indigo-600 p-10 text-white text-center\"\u003e\n          \u003cdiv className=\"bg-white w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg\"\u003e\n            \u003cspan className=\"text-4xl\"\u003e😊\u003c/span\u003e\n          \u003c/div\u003e\n          \u003ch2 className=\"text-3xl font-bold\"\u003eเริ่มรอยยิ้มกับ Smile Slip Pro\u003c/h2\u003e\n          \u003cp className=\"opacity-90 mt-2 font-light italic\"\u003e\"ให้ทุกการทำบัญชี... เป็นเรื่องน่ารักสำหรับคุณ\"\u003c/p\u003e\n        \u003c/div\u003e\n\n        \u003cform onSubmit={handleSubmit} className=\"p-10 space-y-8\"\u003e\n          \u003cdiv className=\"flex gap-4 p-1.5 bg-slate-100 rounded-2xl\"\u003e\n            \u003cbutton \n              type=\"button\"\n              onClick={() =\u003e setUserType('individual')}\n              className={`flex-1 py-3 rounded-xl font-bold transition-all ${userType === 'individual' ? 'bg-white shadow-md text-indigo-600 scale-100' : 'text-slate-500 scale-95'}`}\n            \u003e\n              บุคคลธรรมดา\n            \u003c/button\u003e\n            \u003cbutton \n              type=\"button\"\n              onClick={() =\u003e setUserType('corporate')}\n              className={`flex-1 py-3 rounded-xl font-bold transition-all ${userType === 'corporate' ? 'bg-white shadow-md text-indigo-600 scale-100' : 'text-slate-500 scale-95'}`}\n            \u003e\n              นิติบุคคล\n            \u003c/button\u003e\n          \u003c/div\u003e\n\n          \u003cdiv className=\"space-y-6\"\u003e\n            \u003cdiv className=\"group\"\u003e\n              \u003clabel className=\"block text-sm font-bold text-slate-700 mb-2 ml-1\"\u003eชื่อร้านหรือชื่อบริษัทของคุณ\u003c/label\u003e\n              \u003cdiv className=\"relative transition-all focus-within:scale-[1.01]\"\u003e\n                \u003cBuilding2 className=\"absolute left-4 top-3.5 text-indigo-400\" size={20} /\u003e\n                \u003cinput required className=\"w-full pl-12 pr-4 py-3.5 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-100 focus:border-indigo-500 outline-none transition-all\" placeholder=\"ระบุชื่อตามใบจดทะเบียน\" /\u003e\n              \u003c/div\u003e\n            \u003c/div\u003e\n\n            {userType === 'corporate' \u0026\u0026 (\n              \u003cdiv className=\"animate-in fade-in slide-in-from-top-4\"\u003e\n                \u003clabel className=\"block text-sm font-bold text-slate-700 mb-2 ml-1\"\u003eเลขประจำตัวผู้เสียภาษี (Tax ID)\u003c/label\u003e\n                \u003cdiv className=\"relative transition-all focus-within:scale-[1.01]\"\u003e\n                  \u003cCreditCard className=\"absolute left-4 top-3.5 text-indigo-400\" size={20} /\u003e\n                  \u003cinput required className=\"w-full pl-12 pr-4 py-3.5 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-100 focus:border-indigo-500 outline-none transition-all\" placeholder=\"ระบุเลข 13 หลัก\" /\u003e\n                \u003c/div\u003e\n              \u003c/div\u003e\n            )}\n\n            \u003cdiv className=\"grid grid-cols-1 md:grid-cols-2 gap-6\"\u003e\n              \u003cdiv\u003e\n                \u003clabel className=\"block text-sm font-bold text-slate-700 mb-2 ml-1\"\u003eเบอร์โทรศัพท์\u003c/label\u003e\n                \u003cdiv className=\"relative transition-all focus-within:scale-[1.01]\"\u003e\n                  \u003cPhone className=\"absolute left-4 top-3.5 text-indigo-400\" size={20} /\u003e\n                  \u003cinput required className=\"w-full pl-12 pr-4 py-3.5 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-100 focus:border-indigo-500 outline-none transition-all\" placeholder=\"08x-xxx-xxxx\" /\u003e\n                \u003c/div\u003e\n              \u003c/div\u003e\n              \u003cdiv className=\"flex flex-col justify-end\"\u003e\n                 \u003cp className=\"text-xs text-slate-400 italic mb-2\"\u003e* ข้อมูลนี้จะถูกเก็บเป็นความลับนะคะ\u003c/p\u003e\n              \u003c/div\u003e\n            \u003c/div\u003e\n\n            \u003cdiv\u003e\n              \u003clabel className=\"block text-sm font-bold text-slate-700 mb-2 ml-1\"\u003eที่อยู่สำนักงาน / ร้านค้า\u003c/label\u003e\n              \u003cdiv className=\"relative transition-all focus-within:scale-[1.01]\"\u003e\n                \u003cMapPin className=\"absolute left-4 top-3.5 text-indigo-400\" size={20} /\u003e\n                \u003ctextarea required className=\"w-full pl-12 pr-4 py-3.5 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-100 focus:border-indigo-500 outline-none transition-all\" rows=\"3\" placeholder=\"ระบุที่อยู่เพื่อใช้ออกใบเสร็จค่ะ\"\u003e\u003c/textarea\u003e\n              \u003c/div\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n\n          \u003cbutton \n            disabled={loading}\n            className=\"w-full py-4 bg-indigo-600 text-white rounded-2xl font-bold text-xl shadow-xl hover:bg-indigo-700 hover:shadow-indigo-200 transition-all transform active:scale-95 flex items-center justify-center gap-2\"\n          \u003e\n            {loading ? \"กำลังบันทึก...\" : \u003c\u003e\u003cHeart size={20} fill=\"white\" /\u003e บันทึกและเริ่มรอยยิ้ม\u003c/\u003e}\n          \u003c/button\u003e\n          \n          \u003cp className=\"text-center text-slate-400 text-sm\"\u003e\n            การกดปุ่มบันทึก หมายถึงคุณยินยอมให้ \u003cbr/\u003e\u003cb\u003eบริษัท สยาม โกลบอล เน็ทเวิร์ค เอ็นเตอร์ไพรส์ จำกัด\u003c/b\u003e ดูแลข้อมูลของคุณค่ะ\n          \u003c/p\u003e\n        \u003c/form\u003e\n      \u003c/div\u003e\n    \u003c/div\u003e\n  );\n}\n"}}
