I0414 10:27:36.766583    2720 conn_opt.go:53] jsonrpc2: --> notif: textDocument/didChange: {"textDocument":{"uri":"file:///home/smileslip_official/smileslip-dashboard/pages/register.js","version":3},"contentChanges":[{"range":{"start":{"line":2,"character":0},"end":{"line":24,"character":0}},"rangeLength":1412,"text":"import { Building2, MapPin, Phone, CreditCard, Heart, User } from 'lucide-react';\nimport axios from 'axios';\n\nexport default function Register() {\n  const router = useRouter();\n  const { userId, name } = router.query;\n  \n  const [userType, setUserType] = useState('individual');\n  const [formData, setFormData] = useState({\n    shopName: '',\n    taxId: '',\n    phone: '',\n    address: ''\n  });\n  const [loading, setLoading] = useState(false);\n\n  // บันทึกข้อมูลลง Supabase และส่งข้อความ LINE\n  const handleSubmit = async (e) =\u003e {\n    e.preventDefault();\n    if (!userId) {\n      alert(\"ไม่พบรหัส LINE ของคุณ กรุณากลับไปล็อกอินใหม่อีกครั้งนะคะ\");\n      return;\n    }\n    \n    setLoading(true);\n    try {\n      // ยิงข้อมูลไปที่หลังบ้าน (API ที่เราเขียนไว้ก่อนหน้านี้)\n      await axios.post('/api/register', {\n        ...formData,\n        userType,\n        lineUserId: userId,\n        ownerName: name || 'คุณลูกค้า'\n      });\n\n      alert(\"น้อง Smile Slip บันทึกข้อมูลบริษัทของคุณเรียบร้อยแล้วค่ะ! ✨\");\n      // เมื่อเสร็จแล้วให้พาไปหน้า Dashboard (ที่เรากำลังจะสร้าง)\n      router.push('/dashboard');\n    } catch (err) {\n      console.error(err);\n      alert(\"เกิดข้อผิดพลาดในการบันทึกข้อมูล กรุณาลองใหม่อีกครั้งค่ะ\");\n    }\n    setLoading(false);\n  };\n\n  return (\n    \u003cdiv className=\"min-h-screen bg-slate-50 py-12 px-6 flex justify-center font-sans\"\u003e\n      \u003cdiv className=\"max-w-2xl w-full bg-white rounded-3xl shadow-xl overflow-hidden border border-indigo-50\"\u003e\n        \u003cdiv className=\"bg-indigo-600 p-10 text-white text-center\"\u003e\n          \u003cdiv className=\"bg-white w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-4 text-4xl shadow-lg\"\u003e😊\u003c/div\u003e\n          \u003ch2 className=\"text-3xl font-bold\"\u003eข้อมูลนิติบุคคล / ร้านค้า\u003c/h2\u003e\n          \u003cp className=\"opacity-90 mt-2\"\u003eสวัสดีค่ะคุณ \u003cspan className=\"font-bold underline\"\u003e{name || 'ลูกค้า'}\u003c/span\u003e ยินดีที่ได้รู้จักนะคะ!\u003c/p\u003e\n        \u003c/div\u003e\n\n        \u003cform onSubmit={handleSubmit} className=\"p-10 space-y-6\"\u003e\n          \u003cdiv className=\"p-4 bg-indigo-50 rounded-2xl flex items-center gap-3 border border-indigo-100 mb-4\"\u003e\n            \u003cUser className=\"text-indigo-600\" size={20} /\u003e\n            \u003cp className=\"text-sm text-indigo-700\"\u003e\u003cb\u003eLINE ID:\u003c/b\u003e {userId || 'กำลังดึงข้อมูล...'}\u003c/p\u003e\n          \u003c/div\u003e\n\n          \u003cdiv className=\"flex gap-4 p-1.5 bg-slate-100 rounded-2xl\"\u003e\n            \u003cbutton type=\"button\" onClick={() =\u003e setUserType('individual')}\n              className={`flex-1 py-3 rounded-xl font-bold transition-all ${userType === 'individual' ? 'bg-white shadow-md text-indigo-600' : 'text-slate-500'}`}\u003e\n              บุคคลธรรมดา\n            \u003c/button\u003e\n            \u003cbutton type=\"button\" onClick={() =\u003e setUserType('corporate')}\n              className={`flex-1 py-3 rounded-xl font-bold transition-all ${userType === 'corporate' ? 'bg-white shadow-md text-indigo-600' : 'text-slate-500'}`}\u003e\n              นิติบุคคล\n            \u003c/button\u003e\n          \u003c/div\u003e\n\n          \u003cdiv className=\"space-y-4\"\u003e\n            \u003cdiv\u003e\n              \u003clabel className=\"block text-sm font-bold text-slate-700 mb-2\"\u003eชื่อร้าน หรือ ชื่อบริษัท\u003c/label\u003e\n              \u003cdiv className=\"relative\"\u003e\n                \u003cBuilding2 className=\"absolute left-4 top-3.5 text-slate-400\" size={20} /\u003e\n                \u003cinput required value={formData.shopName} onChange={(e) =\u003e setFormData({...formData, shopName: e.target.value})}\n                  className=\"w-full pl-12 pr-4 py-3.5 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-100 outline-none\" placeholder=\"บริษัท สยาม โกลบอล เน็ทเวิร์คฯ\" /\u003e\n              \u003c/div\u003e\n            \u003c/div\u003e\n\n            {userType === 'corporate' \u0026\u0026 (\n              \u003cdiv className=\"animate-in fade-in slide-in-from-top-4\"\u003e\n                \u003clabel className=\"block text-sm font-bold text-slate-700 mb-2\"\u003eเลขประจำตัวผู้เสียภาษี (Tax ID)\u003c/label\u003e\n                \u003cdiv className=\"relative\"\u003e\n                  \u003cCreditCard className=\"absolute left-4 top-3.5 text-slate-400\" size={20} /\u003e\n                  \u003cinput required value={formData.taxId} onChange={(e) =\u003e setFormData({...formData, taxId: e.target.value})}\n                    className=\"w-full pl-12 pr-4 py-3.5 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-100 outline-none\" placeholder=\"0505565019236\" /\u003e\n                \u003c/div\u003e\n              \u003c/div\u003e\n            )}\n\n            \u003cdiv\u003e\n              \u003clabel className=\"block text-sm font-bold text-slate-700 mb-2\"\u003eเบอร์โทรศัพท์ติดต่อ\u003c/label\u003e\n              \u003cdiv className=\"relative\"\u003e\n                \u003cPhone className=\"absolute left-4 top-3.5 text-slate-400\" size={20} /\u003e\n                \u003cinput required value={formData.phone} onChange={(e) =\u003e setFormData({...formData, phone: e.target.value})}\n                  className=\"w-full pl-12 pr-4 py-3.5 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-100 outline-none\" placeholder=\"08x-xxx-xxxx\" /\u003e\n              \u003c/div\u003e\n            \u003c/div\u003e\n\n            \u003cdiv\u003e\n              \u003clabel className=\"block text-sm font-bold text-slate-700 mb-2\"\u003eที่อยู่สำนักงาน / ร้านค้า\u003c/label\u003e\n              \u003cdiv className=\"relative\"\u003e\n                \u003cMapPin className=\"absolute left-4 top-3.5 text-slate-400\" size={20} /\u003e\n                \u003ctextarea required value={formData.address} onChange={(e) =\u003e setFormData({...formData, address: e.target.value})}\n                  className=\"w-full pl-12 pr-4 py-3.5 border border-slate-200 rounded-2xl focus:ring-4 focus:ring-indigo-100 outline-none\" rows=\"3\" placeholder=\"ระบุที่อยู่เพื่อใช้สำหรับระบบบัญชีค่ะ\"\u003e\u003c/textarea\u003e\n              \u003c/div\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n\n          \u003cbutton disabled={loading} className=\"w-full py-4 bg-indigo-600 text-white rounded-2xl font-bold text-xl shadow-xl hover:bg-indigo-700 active:scale-95 transition-all flex items-center justify-center gap-2\"\u003e\n            {loading ? \"กำลังบันทึกรอยยิ้ม...\" : \u003c\u003e\u003cHeart size={20} fill=\"white\" /\u003e บันทึกและเริ่มใช้งาน\u003c/\u003e}\n          \u003c/button\u003e\n"}]}
