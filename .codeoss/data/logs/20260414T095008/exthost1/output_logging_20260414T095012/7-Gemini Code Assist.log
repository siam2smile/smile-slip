I0414 09:57:08.576704    2020 conn_opt.go:53] jsonrpc2: --> notif: textDocument/didOpen: {"textDocument":{"uri":"file:///home/smileslip_official/smileslip-dashboard/pages/api/register.js","languageId":"javascript","version":1,"text":"import { createClient } from '@supabase/supabase-js';\nimport axios from 'axios';\n\nconst supabase = createClient(process.env.SUPABASE_URL, process.env.SUPABASE_KEY);\n\nexport default async function handler(req, res) {\n  if (req.method !== 'POST') return res.status(405).json({ message: 'Method not allowed' });\n\n  const { shopName, userType, taxId, phone, address, lineUserId, ownerName } = req.body;\n\n  try {\n    // 1. บันทึกข้อมูลลง Supabase\n    const { data, error } = await supabase\n      .from('shop_profiles')\n      .update({ \n        shop_name: shopName,\n        user_type: userType,\n        tax_id: taxId,\n        phone: phone,\n        address: address\n      })\n      .eq('owner_line_id', lineUserId);\n\n    if (error) throw error;\n\n    // 2. ส่งข้อความทักทายฉบับ \"น้อง Smile Slip\" ผ่าน Messaging API (ตึก 1)\n    const message = {\n      to: lineUserId,\n      messages: [{\n        type: 'text',\n        text: `สวัสดีค่ะคุณ ${ownerName} 😊 น้อง Smile Slip ยินดีที่ได้ดูแลบัญชีให้คุณนะคะ!\\n\\nตอนนี้ระบบของ ${shopName} พร้อมใช้งาน 100% แล้วค่ะ\\n📍 ประเภทธุรกิจ: ${userType === 'corporate' ? 'นิติบุคคล' : 'บุคคลธรรมดา'}\\n📋 Tax ID: ${taxId || '-'}\\n📞 เบอร์ติดต่อ: ${phone}\\n\\nนับจากนี้ไป ทุกสลิปที่ส่งเข้ามา น้องจะคอยช่วยดูแลและสรุปยอดให้คุณมีรอยยิ้มในทุกวันเลยค่ะ! ✨`\n      }]\n    };\n\n    await axios.post('https://api.line.me/v2/bot/message/push', message, {\n      headers: {\n        'Content-Type': 'application/json',\n        'Authorization': `Bearer ${process.env.LINE_CHANNEL_ACCESS_TOKEN}`\n      }\n    });\n\n    res.status(200).json({ success: true });\n  } catch (err) {\n    console.error(err);\n    res.status(500).json({ error: 'Failed to register' });\n  }\n}\n"}}
