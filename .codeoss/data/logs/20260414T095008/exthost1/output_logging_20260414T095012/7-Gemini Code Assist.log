y-16 px-6 max-w-6xl mx-auto grid md:grid-cols-3 gap-8\"\u003e\n        \u003cdiv className=\"p-8 bg-white rounded-2xl shadow-sm border border-slate-100\"\u003e\n          \u003cZap className=\"text-indigo-600 mb-4\" size={40} /\u003e\n          \u003ch3 className=\"text-xl font-bold mb-2\"\u003eAI Scan 24/7\u003c/h3\u003e\n          \u003cp className=\"text-slate-600\"\u003eอ่านสลิปรายรับและบิลรายจ่ายอัตโนมัติ ไม่ต้องคีย์เองให้เหนื่อย\u003c/p\u003e\n        \u003c/div\u003e\n        \u003cdiv className=\"p-8 bg-white rounded-2xl shadow-sm border border-slate-100\"\u003e\n          \u003cUsers className=\"text-indigo-600 mb-4\" size={40} /\u003e\n          \u003ch3 className=\"text-xl font-bold mb-2\"\u003eStaff Management\u003c/h3\u003e\n          \u003cp className=\"text-slate-600\"\u003eคุมพนักงาน PR/Staff ได้เบ็ดเสร็จ ดึงคนเข้า-ออกกลุ่มได้ทันที ปลอดภัย 100%\u003c/p\u003e\n        \u003c/div\u003e\n        \u003cdiv className=\"p-8 bg-white rounded-2xl shadow-sm border border-slate-100\"\u003e\n          \u003cBarChart3 className=\"text-indigo-600 mb-4\" size={40} /\u003e\n          \u003ch3 className=\"text-xl font-bold mb-2\"\u003eBusiness Summary\u003c/h3\u003e\n          \u003cp className=\"text-slate-600\"\u003eแดชบอร์ดสรุปยอดนิติบุคคล ดูบัญชีรายวันได้ทุกที่ทุกเวลา\u003c/p\u003e\n        \u003c/div\u003e\n      \u003c/section\u003e\n\n      {/* Footer */}\n      \u003cfooter className=\"py-12 bg-slate-900 text-white text-center\"\u003e\n        \u003cp className=\"opacity-60\"\u003e© 2026 Siam Global Network Enterprise Co., Ltd.\u003c/p\u003e\n        \u003cp className=\"text-sm opacity-40 mt-2\"\u003eเลขทะเบียนนิติบุคคล 05 055-650-19236\u003c/p\u003e\n      \u003c/footer\u003e\n    \u003c/div\u003e\n  );\n}\n"}}
